{
  "name": "adi-pro-ultimate",
  "version": "2.0.0",
  "type": "module",
  "description": "Adi Pro Ultimate 2026 Sovereign by Ewelina Lesiak - Windows Desktop App",
  "main": "main.js",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "start": "electron .",
    "build-win": "electron-builder --win portable"
  },
  "author": "Ewelina Lesiak",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "electron": "^25.0.0",
    "electron-builder": "^24.4.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0"
  },
  "build": {
    "appId": "com.ewelinalesiak.adipro",
    "productName": "Adi Pro Ultimate 2026 Sovereign",
    "win": {
      "target": "portable",
      "icon": "https://cdn-icons-png.flaticon.com/512/1698/1698535.png"
    }
  },
  "dependencies": {
    "@google/genai": "^1.45.0",
    "@vitejs/plugin-react": "^5.1.4",
    "d3": "^7.9.0",
    "express": "^5.2.1",
    "lucide-react": "^0.575.0",
    "motion": "^12.34.2",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0",
    "tsx": "^4.21.0",
    "vite": "^7.3.1"
  }
}
